{
  "name": "karea-mcp",
  "mcpName": "io.github.starecz/karea-mcp",
  "version": "0.4.1",
  "description": "MCP server for Karea task management - 44 tools for Claude Code, Cursor, and other MCP clients to create, edit, close, and recap your dev tasks",
  "bin": {
    "karea-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --target node18 --clean",
    "dev": "tsx src/index.ts",
    "sync-metadata": "node scripts/sync-metadata.mjs",
    "prepublishOnly": "npm run sync-metadata && npm run build"
  },
  "keywords": [
    "mcp",
    "karea",
    "task-management",
    "claude",
    "cursor",
    "model-context-protocol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/starecz/karea-mcp.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "^5.6.3"
  }
}
